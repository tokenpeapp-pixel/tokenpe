{
    "buildCommand": "next build",
    "outputDirectory": ".next",
    "framework": "nextjs",
    "crons": [
        {
            "path": "/api/cron/followups",
            "schedule": "30 4 * * *"
        },
        {
            "path": "/api/cron/trial-reminders",
            "schedule": "30 0 * * *"
        },
        {
            "path": "/api/cron/expire-subscriptions",
            "schedule": "0 1 * * *"
        }
    ]
}
